OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-5.4

# Phải khớp AGENT_BRIDGE_SECRET trong .env ở gốc repo.
AGENT_BRIDGE_SECRET=change-me-local-dev-secret
NODE_BRIDGE_BASE_URL=http://localhost:3000
PYTHON_AGENT_PORT=8787

# --- RAG pháp lý (tùy chọn, mặc định TẮT). Xem legal_rag/README.md ---
# LEGAL_RAG_ENABLED=1
# LEGAL_RAG_SOURCE=editor         # editor (tra trong tài liệu đang mở) | corpus
# LEGAL_RAG_BACKEND=memory        # memory | qdrant | pgvector
# LEGAL_RAG_RERANK=0
# LEGAL_RAG_EMBEDDING_MODEL=BAAI/bge-m3
# LEGAL_RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# LEGAL_RAG_QDRANT_URL=http://localhost:6333
# LEGAL_RAG_QDRANT_COLLECTION=vn_legal
# LEGAL_RAG_TOP_K=20
# LEGAL_RAG_RERANK_TOP_K=6
